@model LoginViewModel
<section class="login-page login-no-white-gap">
    <div class="login-overlay"></div>

    <div class="login-wrapper">

        <div class="login-card">

            <div class="login-logo">
                <i class="bi bi-fire"></i>
                <h2>SAFFRON TABLE</h2>
                <span>THE FINEST DINING EXPERIENCE</span>
            </div>

            <h1>Welcome Back</h1>
            <p class="login-subtitle">Login to continue your reservation.</p>

            <div class="divider">
                <span></span>
                <i class="bi bi-diamond-fill"></i>
                <span></span>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form asp-action="Login" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group">
                    <label>Email</label>
                    <div class="input-box">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" placeholder="Enter your email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-box">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" type="password" placeholder="Enter your password" />
                        <i class="bi bi-eye password-eye"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="login-options">
                    <label>
                        <input type="checkbox" />
                        Remember me
                    </label>

                    <a href="#">Forgot Password?</a>
                </div>

                <button type="submit" class="login-btn">LOGIN</button>

                <div class="or-line">
                    <span></span>
                    <p>or</p>
                    <span></span>
                </div>

                <div class="social-icons">
                    <a href="#"><i class="bi bi-google"></i></a>
                    <a href="#"><i class="bi bi-facebook"></i></a>
                    <a href="#"><i class="bi bi-apple"></i></a>
                </div>

                <p class="register-link">
                    Don’t have an account?
                    <a asp-controller="Account" asp-action="Register">Register</a>
                </p>

            </form>

        </div>

    </div>
</section>