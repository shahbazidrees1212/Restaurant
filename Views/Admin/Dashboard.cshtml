@{ ViewData["Title"] = "Admin Dashboard"; var reservations = ViewBag.Reservations as List<Reservation> ?? new(); var messages = ViewBag.Messages as List<ContactMessage> ?? new(); }
<section class="page-hero"><div class="container"><h1>Admin Dashboard</h1><p>Reservation and contact overview.</p></div></section>
<section class="section-padding"><div class="container"><div class="row g-4 mb-4"><div class="col-md-4"><div class="stat-card"><h2>@reservations.Count</h2><p>Reservations</p></div></div><div class="col-md-4"><div class="stat-card"><h2>@messages.Count</h2><p>Messages</p></div></div><div class="col-md-4"><div class="stat-card"><h2>PKR</h2><p>Ready for POS</p></div></div></div><div class="card-modern p-4"><h3>Latest Reservations</h3><div class="table-responsive"><table class="table"><thead><tr><th>Name</th><th>Date</th><th>Time</th><th>Guests</th><th>Status</th></tr></thead><tbody>@foreach(var r in reservations){<tr><td>@r.FullName</td><td>@r.ReservationDate.ToString("dd MMM yyyy")</td><td>@r.ReservationTime</td><td>@r.Guests</td><td><span class="badge text-bg-warning">@r.Status</span></td></tr>}</tbody></table></div></div></div></section>
