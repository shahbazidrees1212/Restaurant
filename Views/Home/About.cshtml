@{
    ViewData["Title"] = "About";
}

<!-- HERO -->
<section class="page-hero about-hero d-flex align-items-center text-center text-white">
    <div class="container">
        <span class="hero-badge">About Us</span>
        <h1 class="hero-title">About Saffron Table</h1>
        <p class="hero-text">Where modern ambiance meets premium taste.</p>
    </div>
</section>

<!-- STORY -->
<section class="section-padding about-section">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-lg-6">
                <div class="about-img-box">
                    <img src="https://images.unsplash.com/photo-1552566626-52f8b828add9?auto=format&fit=crop&w=900&q=80"
                         class="img-fluid"
                         alt="Restaurant" />
                </div>
            </div>

            <div class="col-lg-6">
                <span class="section-small-title">Our Story</span>

                <h2 class="about-title">
                    Built for food lovers and memorable dining.
                </h2>

                <p class="about-text">
                    Saffron Table is a premium restaurant concept focused on fresh ingredients,
                    elegant presentation, family comfort, and fast online reservation management.
                    We deliver unforgettable dining experiences with a modern touch.
                </p>

                <div class="row g-3 mt-4">

                    <div class="col-6">
                        <div class="about-stat">
                            <h2>15+</h2>
                            <p>Years Experience</p>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="about-stat">
                            <h2>50+</h2>
                            <p>Signature Items</p>
                        </div>
                    </div>

                </div>

                <a href="/Reservation/Create" class="btn btn-warning rounded-pill px-5 mt-4 fw-bold">
                    Book Table
                </a>
            </div>

        </div>
    </div>
</section>