@model RestaurantMvcUltimatePro.Models.Order

@{
    ViewData["Title"] = "Order Success";
}

<section class="success-page">
    <div class="container">
        <div class="success-card">

            <div class="success-icon">
                <i class="bi bi-check-lg"></i>
            </div>

            <h1>Order Placed Successfully</h1>

            <p>
                Thank you, <strong>@Model.CustomerName</strong>. Your order has been placed.
            </p>

            <div class="success-info">
                <div>
                    <small>Order Number</small>
                    <strong>#@Model.Id</strong>
                </div>

                <div>
                    <small>Total Amount</small>
                    <strong>Rs. @Model.TotalAmount</strong>
                </div>

                <div>
                    <small>Status</small>
                    <strong>@Model.Status</strong>
                </div>
            </div>

            <div class="success-actions">
                <a asp-controller="Order"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   class="btn btn-warning rounded-pill px-5 py-3 fw-bold">
                    View Order
                </a>

                <a asp-controller="Menu"
                   asp-action="Index"
                   class="btn btn-dark rounded-pill px-5 py-3 fw-bold">
                    Continue Shopping
                </a>
            </div>

        </div>
    </div>
</section>

<style>
    .success-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #fff7e6, #f8f5ef);
        display: flex;
        align-items: center;
        padding: 70px 0;
    }

    .success-card {
        background: #fff;
        max-width: 850px;
        margin: auto;
        text-align: center;
        border-radius: 35px;
        padding: 70px 40px;
        box-shadow: 0 25px 70px rgba(0,0,0,0.08);
    }

    .success-icon {
        width: 100px;
        height: 100px;
        background: #dcfce7;
        color: #16a34a;
        border-radius: 50%;
        margin: 0 auto 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 55px;
    }

    .success-card h1 {
        font-size: 42px;
        font-weight: 900;
        color: #111;
    }

    .success-card p {
        color: #777;
        font-size: 17px;
        margin-top: 12px;
    }

    .success-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 15px;
        margin: 35px 0;
    }

        .success-info div {
            background: #fff8ea;
            padding: 20px;
            border-radius: 20px;
        }

        .success-info small {
            display: block;
            color: #777;
            margin-bottom: 6px;
        }

        .success-info strong {
            font-size: 20px;
        }

    .success-actions {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
    }
</style>