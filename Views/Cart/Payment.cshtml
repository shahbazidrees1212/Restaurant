@{
    ViewData["Title"] = "Payment";
}

<section class="payment-page">
    <div class="payment-card">

        <div class="payment-header">
            <span class="payment-icon">💳</span>
            <h1>Complete Payment</h1>
            <p>Choose your selected payment option and complete your order securely.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert-box alert-error">@TempData["Error"]</div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert-box alert-success">@TempData["Success"]</div>
        }

        <div class="payment-summary">
            <div>
                <span>Payment Method</span>
                <strong>@ViewBag.PaymentMethod</strong>
            </div>

            <div>
                <span>Total Amount</span>
                <strong>PKR @ViewBag.Amount</strong>
            </div>
        </div>

        @if (ViewBag.PaymentMethod == "JazzCash")
        {
            <div class="payment-info jazzcash">
                <h3>JazzCash Payment</h3>
                <p>You will be redirected to JazzCash secure payment gateway.</p>
            </div>

            <form asp-controller="Cart" asp-action="JazzCashPayment" method="get" class="payment-form">
                <input type="hidden" name="amount" value="@ViewBag.Amount" />
                <button type="submit" class="pay-btn">Pay Now with JazzCash</button>
            </form>
        }
        else if (ViewBag.PaymentMethod == "EasyPaisa")
        {
            <div class="payment-info easypaisa">
                <h3>EasyPaisa Payment</h3>
                <p>You will be redirected to EasyPaisa secure payment gateway.</p>
            </div>

            <form asp-controller="Cart" asp-action="EasyPaisaPayment" method="get" class="payment-form">
                <input type="hidden" name="amount" value="@ViewBag.Amount" />
                <button type="submit" class="pay-btn">Pay Now with EasyPaisa</button>
            </form>
        }
        else if (ViewBag.PaymentMethod == "Card Payment")
        {
            <div class="payment-info card-payment">
                <h3>Card Payment</h3>
                <p>Enter your debit/credit card details to complete payment.</p>
            </div>

            <form action="/Cart/CardPayment" method="get" class="payment-form">
                <input type="hidden" name="amount" value="@ViewBag.Amount" />
                <button type="submit" class="pay-btn">Continue to Card Payment</button>
            </form>
        }
        else
        {
            <div class="alert-box alert-error">Invalid payment method selected.</div>
        }

        <a asp-controller="Cart" asp-action="Index" class="back-cart">← Back to Cart</a>

    </div>
</section>