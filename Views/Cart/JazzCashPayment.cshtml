@model SortedDictionary<string, string>

@{
    ViewData["Title"] = "JazzCash Payment";
}

<section class="payment-page">
    <div class="payment-card">
        <h1>Redirecting to JazzCash...</h1>
        <p>Please wait. You are being redirected to JazzCash secure payment gateway.</p>

        <form id="jazzCashForm" method="post" action="@Model["gatewayUrl"]">
            @foreach (var item in Model)
            {
                if (item.Key != "gatewayUrl")
                {
                    <input type="hidden" name="@item.Key" value="@item.Value" />
                }
            }

            <button type="submit" class="pay-btn">
                Pay with JazzCash
            </button>
        </form>
    </div>
</section>

<script>
    document.getElementById("jazzCashForm").submit();
</script>