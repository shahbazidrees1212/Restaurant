@model List<RestaurantMvcUltimatePro.Models.CartItem>

@{
    ViewData["Title"] = "Cart";
    decimal grandTotal = Model != null && Model.Any() ? Model.Sum(x => x.Total) : 0;
}

<section class="cart-page">
    <div class="cart-container">

        @if (TempData["Success"] != null)
        {
            <div class="modern-alert">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="error-alert">@TempData["Error"]</div>
        }

        <div class="cart-header">
            <div>
                <span class="section-label">Your Cart</span>
                <h1>Review & Checkout</h1>
                <p>Check your order, add delivery details, and choose payment method.</p>
            </div>

            <a href="/Menu" class="continue-top-btn">← Continue Shopping</a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-cart-box">
                <div class="empty-cart-icon">🛒</div>
                <h2>Your Cart is Empty</h2>
                <p>Please add delicious items from the menu.</p>
                <a href="/Menu">Back to Menu</a>
            </div>
        }
        else
        {
            <div class="cart-layout">

                <div class="cart-items-card">
                    <h2 class="cart-section-title">Cart Items</h2>

                    @foreach (var item in Model)
                    {
                        <div class="cart-item">

                            <img src="@item.ImageUrl" alt="@item.Name" />

                            <div class="cart-item-info">
                                <h3>@item.Name</h3>
                                <p>PKR @item.Price</p>

                                <form action="/Cart/UpdateQuantity" method="post" class="qty-form">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@item.MenuItemId" />

                                    <input type="number"
                                           name="quantity"
                                           value="@item.Quantity"
                                           min="1"
                                           max="99"
                                           required />

                                    <button type="submit">Update</button>
                                </form>
                            </div>

                            <div class="cart-item-total">
                                <span>Total</span>
                                <strong>PKR @item.Total</strong>

                                <form action="/Cart/Remove" method="post">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@item.MenuItemId" />

                                    <button type="submit"
                                            class="remove-btn"
                                            onclick="return confirm('Remove this item from cart?');">
                                        Remove
                                    </button>
                                </form>
                            </div>

                        </div>
                    }
                </div>

                <div class="checkout-card">

                    <h2>Order Summary</h2>

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <strong>PKR @grandTotal</strong>
                    </div>

                    <div class="summary-row">
                        <span>Delivery</span>
                        <strong>Free</strong>
                    </div>

                    <hr />

                    <div class="summary-total">
                        <span>Grand Total</span>
                        <strong>PKR @grandTotal</strong>
                    </div>

                    <h3>Customer Information</h3>

                    <form action="/Cart/Checkout" method="post" class="checkout-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="grandTotal" value="@grandTotal" />

                        <div class="customer-form">

                            <div class="form-group">
                                <label>Full Name</label>
                                <input type="text"
                                       name="customerName"
                                       placeholder="Enter full name"
                                       minlength="3"
                                       maxlength="80"
                                       required />
                            </div>

                            <div class="form-group">
                                <label>Email Address</label>
                                <input type="email"
                                       name="customerEmail"
                                       placeholder="example@email.com"
                                       required />
                            </div>

                            <div class="form-group">
                                <label>Phone Number</label>
                                <input type="tel"
                                       name="phone"
                                       placeholder="03XXXXXXXXX"
                                       pattern="03[0-9]{9}"
                                       title="Enter valid Pakistani phone number like 03XXXXXXXXX"
                                       required />
                            </div>

                            <div class="form-group">
                                <label>Delivery Address</label>
                                <textarea name="address"
                                      placeholder="Enter complete delivery address"
                                      rows="3"
                                      minlength="10"
                                      required></textarea>
                            </div>

                        </div>

                        <h3>Select Payment Method</h3>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="Cash On Delivery" checked required />
                            <span>
                                <b>💵 Cash On Delivery</b>
                                <small>Pay when your order arrives</small>
                            </span>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="JazzCash" />
                            <span>
                                <b>📱 JazzCash</b>
                                <small>Pay with JazzCash wallet</small>
                            </span>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="EasyPaisa" />
                            <span>
                                <b>📲 EasyPaisa</b>
                                <small>Pay with EasyPaisa account</small>
                            </span>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="Card Payment" />
                            <span>
                                <b>💳 Card Payment</b>
                                <small>Pay with Visa / Mastercard</small>
                            </span>
                        </label>

                        <button type="submit" class="checkout-btn">
                            Proceed to Payment
                        </button>
                    </form>

                    <form action="/Cart/Clear" method="post">
                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="clear-btn"
                                onclick="return confirm('Are you sure you want to clear cart?');">
                            Clear Cart
                        </button>
                    </form>

                </div>

            </div>
        }

    </div>
</section>