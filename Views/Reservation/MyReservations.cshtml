@model List<Reservation>

@{
    ViewData["Title"] = "My Reservations";
}

<section class="reservations-page">

    <div class="container">

        <!-- Header -->
        <div class="reservation-header">

            <div>
                <span class="reservation-tag">
                    Dining Experience
                </span>

                <h1>My Reservations</h1>

                <p>
                    View and manage your table bookings at Saffron Table.
                </p>
            </div>

            <a asp-controller="Reservation"
               asp-action="Create"
               class="new-booking-btn">

                <i class="bi bi-plus-circle"></i>
                Book New Table
            </a>

        </div>

        <!-- Reservation Cards -->
        <div class="row g-4">

            @if (Model != null && Model.Any())
            {
                @foreach (var reservation in Model)
                {
                    <div class="col-lg-6">

                        <div class="reservation-card">

                            <!-- Top -->
                            <div class="reservation-top">

                                <div>

                                    <span class="reservation-id">
                                        Reservation #@reservation.Id
                                    </span>

                                    <h3>
                                        @reservation.FullName
                                    </h3>

                                </div>

                                <span class="status confirmed">
                                    Confirmed
                                </span>

                            </div>

                            <!-- Info -->
                            <div class="reservation-info">

                                <div class="info-item">
                                    <i class="bi bi-calendar-event"></i>

                                    <div>
                                        <span>Date</span>

                                        <strong>
                                            @reservation.ReservationDate.ToString("dd MMM yyyy")
                                        </strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <i class="bi bi-clock"></i>

                                    <div>
                                        <span>Time</span>

                                        <strong>
                                            @reservation.ReservationTime
                                        </strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <i class="bi bi-people"></i>

                                    <div>
                                        <span>Guests</span>

                                        <strong>
                                            @reservation.Guests Persons
                                        </strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <i class="bi bi-envelope"></i>

                                    <div>
                                        <span>Email</span>

                                        <strong>
                                            @reservation.Email
                                        </strong>
                                    </div>
                                </div>

                            </div>

                            <!-- Actions -->
                            <div class="reservation-actions">

                                <a asp-controller="Reservation"
                                   asp-action="Edit"
                                   asp-route-id="@reservation.Id"
                                   class="action-btn edit-btn">

                                    <i class="bi bi-pencil"></i>
                                    Edit
                                </a>

                                <form asp-controller="Reservation"
                                      asp-action="Delete"
                                      asp-route-id="@reservation.Id"
                                      method="post"
                                      class="cancel-form">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="action-btn cancel-btn"
                                            onclick="return confirm('Are you sure you want to cancel this reservation?');">

                                        <i class="bi bi-x-circle"></i>
                                        Cancel
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="col-12">

                    <div class="empty-reservation text-center">

                        <i class="bi bi-calendar-x"></i>

                        <h3>No Reservations Found</h3>

                        <p>
                            You have not booked any tables yet.
                        </p>

                        <a asp-controller="Reservation"
                           asp-action="Create"
                           class="new-booking-btn mt-3">

                            Book Table
                        </a>

                    </div>

                </div>
            }

        </div>

    </div>

</section>