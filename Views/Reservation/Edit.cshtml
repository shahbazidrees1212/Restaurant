@using RestaurantMvcUltimatePro.Models
@model Reservation

@{
    ViewData["Title"] = "Edit Reservation";
}

<section class="reservation-edit-page">

    <div class="reservation-edit-container">

        <div class="edit-header">

            <div>
                <span class="edit-tag">
                    Reservation Update
                </span>

                <h1>Edit Reservation</h1>

                <p>
                    Update your table booking details below.
                </p>
            </div>

            <a asp-controller="Reservation"
               asp-action="MyReservations"
               class="back-btn">

                ← Back Reservations

            </a>

        </div>

        <div class="edit-card">

            <form asp-action="Edit"
                  method="post"
                  class="edit-form">

                <input type="hidden"
                       asp-for="Id" />

                <div class="form-grid">

                    <div class="form-group">

                        <label>
                            Full Name
                        </label>

                        <input asp-for="FullName"
                               class="form-control" />

                    </div>

                    <div class="form-group">

                        <label>
                            Email Address
                        </label>

                        <input asp-for="Email"
                               class="form-control" />

                    </div>

                    <div class="form-group">

                        <label>
                            Reservation Date
                        </label>

                        <input asp-for="ReservationDate"
                               type="date"
                               class="form-control" />

                    </div>

                    <div class="form-group">

                        <label>
                            Reservation Time
                        </label>

                        <input asp-for="ReservationTime"
                               type="time"
                               class="form-control" />

                    </div>

                    <div class="form-group">

                        <label>
                            Number Of Guests
                        </label>

                        <input asp-for="Guests"
                               type="number"
                               class="form-control" />

                    </div>

                </div>

                <div class="edit-actions">

                    <button type="submit"
                            class="save-btn">

                        Save Changes

                    </button>

                </div>

            </form>

        </div>

    </div>

</section>